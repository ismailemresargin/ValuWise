<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.text.Font?>
<?import org.controlsfx.control.CheckComboBox?>

<VBox xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.valuwise.controller.PhoneCompareController">

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
    <VBox spacing="15.0">
        <padding><Insets top="15.0" left="20.0" right="20.0" bottom="10.0" /></padding>

        <Label text="Telefon Karşılaştırma" textFill="#2c3e50">
            <font><Font name="System Bold" size="16.0" /></font>
        </Label>

        <!-- İKİ TELEFON FORMU YAN YANA -->
        <HBox spacing="20.0">

            <!-- TELEFON 1 -->
            <VBox spacing="10.0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #eaf4fb; -fx-border-color: #2980b9; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;">
                <Label text="📱 Telefon 1" textFill="#2980b9">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <GridPane hgap="10.0" vgap="8.0">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="130.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <children>
                        <Label text="Marka:" GridPane.rowIndex="0" />
                        <ComboBox fx:id="marka1ComboBox" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Model:" GridPane.rowIndex="1" />
                        <ComboBox fx:id="model1ComboBox" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label text="Depolama:" GridPane.rowIndex="2" />
                        <ComboBox fx:id="depolama1ComboBox" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label text="Cihaz Yaşı (Ay):" GridPane.rowIndex="3" />
                        <TextField fx:id="yas1Field" promptText="Örn: 12" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <Label text="Pil Sağlığı:" GridPane.rowIndex="4" />
                        <HBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                            <Slider fx:id="pil1Slider" min="50" max="100" value="90" prefWidth="130.0"
                                showTickLabels="true" showTickMarks="true" majorTickUnit="10" />
                            <Label fx:id="pil1Label" text="90%" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" minWidth="38.0" />
                        </HBox>
                        <Label text="Arka Kamera:" GridPane.rowIndex="5" />
                        <Label fx:id="arkaKamera1Label" text="—" style="-fx-font-weight: bold; -fx-text-fill: #2980b9;" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                        <Label text="Ekran:" GridPane.rowIndex="6" />
                        <Label fx:id="ekran1Label" text="—" style="-fx-font-weight: bold; -fx-text-fill: #2980b9;" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                        <Label text="Garanti:" GridPane.rowIndex="7" />
                        <HBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="7">
                            <CheckBox fx:id="garanti1Check" text="Var" />
                            <ComboBox fx:id="garantiAy1ComboBox" promptText="Kalan Süre" prefWidth="130.0" disable="true" />
                        </HBox>
                    </children>
                    <rowConstraints>
                        <RowConstraints minHeight="30.0" /><RowConstraints minHeight="30.0" />
                        <RowConstraints minHeight="30.0" /><RowConstraints minHeight="30.0" />
                        <RowConstraints minHeight="35.0" /><RowConstraints minHeight="30.0" />
                        <RowConstraints minHeight="30.0" /><RowConstraints minHeight="35.0" />
                    </rowConstraints>
                </GridPane>
                <FlowPane hgap="8.0" vgap="6.0">
                    <CheckBox fx:id="kutuFatura1Check" text="Kutu/Fatura" />
                    <CheckBox fx:id="imei1Check" text="İMEİ Kayıtlı" selected="true" />
                    <CheckBox fx:id="besG1Check" text="5G" />
                    <CheckBox fx:id="hizliSarj1Check" text="Hızlı Şarj" />
                </FlowPane>
                <HBox spacing="6.0">
                    <Label text="Hasar/Tamir:" />
                    <CheckComboBox fx:id="hasar1ComboBox" prefWidth="200.0" />
                </HBox>
            </VBox>

            <!-- TELEFON 2 -->
            <VBox spacing="10.0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #fef9e7; -fx-border-color: #e67e22; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;">
                <Label text="📱 Telefon 2" textFill="#e67e22">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <GridPane hgap="10.0" vgap="8.0">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="130.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <children>
                        <Label text="Marka:" GridPane.rowIndex="0" />
                        <ComboBox fx:id="marka2ComboBox" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Model:" GridPane.rowIndex="1" />
                        <ComboBox fx:id="model2ComboBox" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label text="Depolama:" GridPane.rowIndex="2" />
                        <ComboBox fx:id="depolama2ComboBox" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label text="Cihaz Yaşı (Ay):" GridPane.rowIndex="3" />
                        <TextField fx:id="yas2Field" promptText="Örn: 12" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <Label text="Pil Sağlığı:" GridPane.rowIndex="4" />
                        <HBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                            <Slider fx:id="pil2Slider" min="50" max="100" value="90" prefWidth="130.0"
                                showTickLabels="true" showTickMarks="true" majorTickUnit="10" />
                            <Label fx:id="pil2Label" text="90%" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" minWidth="38.0" />
                        </HBox>
                        <Label text="Arka Kamera:" GridPane.rowIndex="5" />
                        <Label fx:id="arkaKamera2Label" text="—" style="-fx-font-weight: bold; -fx-text-fill: #e67e22;" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                        <Label text="Ekran:" GridPane.rowIndex="6" />
                        <Label fx:id="ekran2Label" text="—" style="-fx-font-weight: bold; -fx-text-fill: #e67e22;" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                        <Label text="Garanti:" GridPane.rowIndex="7" />
                        <HBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="7">
                            <CheckBox fx:id="garanti2Check" text="Var" />
                            <ComboBox fx:id="garantiAy2ComboBox" promptText="Kalan Süre" prefWidth="130.0" disable="true" />
                        </HBox>
                    </children>
                    <rowConstraints>
                        <RowConstraints minHeight="30.0" /><RowConstraints minHeight="30.0" />
                        <RowConstraints minHeight="30.0" /><RowConstraints minHeight="30.0" />
                        <RowConstraints minHeight="35.0" /><RowConstraints minHeight="30.0" />
                        <RowConstraints minHeight="30.0" /><RowConstraints minHeight="35.0" />
                    </rowConstraints>
                </GridPane>
                <FlowPane hgap="8.0" vgap="6.0">
                    <CheckBox fx:id="kutuFatura2Check" text="Kutu/Fatura" />
                    <CheckBox fx:id="imei2Check" text="İMEİ Kayıtlı" selected="true" />
                    <CheckBox fx:id="besG2Check" text="5G" />
                    <CheckBox fx:id="hizliSarj2Check" text="Hızlı Şarj" />
                </FlowPane>
                <HBox spacing="6.0">
                    <Label text="Hasar/Tamir:" />
                    <CheckComboBox fx:id="hasar2ComboBox" prefWidth="200.0" />
                </HBox>
            </VBox>

        </HBox>

        <!-- KARŞILAŞTIRMA SONUÇ TABLOSU -->
        <VBox spacing="8.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
            <Label text="Karşılaştırma Sonucu" textFill="#2c3e50">
                <font><Font name="System Bold" size="14.0" /></font>
            </Label>
            <Separator />

            <GridPane hgap="15.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints prefWidth="180.0" />
                    <ColumnConstraints hgrow="ALWAYS" prefWidth="200.0" />
                    <ColumnConstraints hgrow="ALWAYS" prefWidth="200.0" />
                </columnConstraints>
                <children>
                    <Label text="" GridPane.rowIndex="0" />
                    <Label fx:id="baslik1Label" text="Telefon 1" textFill="#2980b9" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <Label fx:id="baslik2Label" text="Telefon 2" textFill="#e67e22" style="-fx-font-weight: bold;" GridPane.columnIndex="2" GridPane.rowIndex="0" />

                    <Label text="Tahmini Değer:" GridPane.rowIndex="1" />
                    <Label fx:id="sonuc1Label" text="—" style="-fx-font-weight: bold; -fx-font-size: 14px;" textFill="#2980b9" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <Label fx:id="sonuc2Label" text="—" style="-fx-font-weight: bold; -fx-font-size: 14px;" textFill="#e67e22" GridPane.columnIndex="2" GridPane.rowIndex="1" />

                    <Label text="Piyasa Aralığı:" GridPane.rowIndex="2" />
                    <Label fx:id="aralik1Label" text="—" style="-fx-font-size: 11px;" textFill="#7f8c8d" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <Label fx:id="aralik2Label" text="—" style="-fx-font-size: 11px;" textFill="#7f8c8d" GridPane.columnIndex="2" GridPane.rowIndex="2" />

                    <Label text="Fark:" GridPane.rowIndex="3" />
                    <Label fx:id="farkLabel" text="—" style="-fx-font-weight: bold; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="3" />

                    <Label text="Daha İyi Alım:" GridPane.rowIndex="4" />
                    <Label fx:id="kazananLabel" text="—" style="-fx-font-weight: bold; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="4" />
                </children>
                <rowConstraints>
                    <RowConstraints minHeight="28.0" /><RowConstraints minHeight="32.0" />
                    <RowConstraints minHeight="28.0" /><RowConstraints minHeight="28.0" />
                    <RowConstraints minHeight="28.0" />
                </rowConstraints>
            </GridPane>
        </VBox>

    </VBox>
    </ScrollPane>

    <Separator />

    <HBox alignment="CENTER" spacing="12.0" style="-fx-padding: 8 25 10 25;">
        <Button defaultButton="true" onAction="#onKarsilastirButtonClick"
                prefHeight="42.0" prefWidth="220.0"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 8;"
                text="TELEFONLARI KARŞILAŞTIR">
            <font><Font name="System Bold" size="13.0" /></font>
        </Button>
        <Button onAction="#onSifirlaButtonClick"
                prefHeight="42.0" prefWidth="110.0"
                style="-fx-background-color: #bdc3c7; -fx-text-fill: #2c3e50; -fx-background-radius: 8;"
                text="SIFIRLA" />
    </HBox>

</VBox>
