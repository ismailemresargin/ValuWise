<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.valuwise.HelloController">
    <VBox spacing="20.0">
        <padding><Insets bottom="20.0" left="30.0" right="30.0" top="20.0" /></padding>
        <children>
            <Label text="Bilgisayar Değeri Hesaplama İçin Veri Girişi" textFill="#2c3e50"><font><Font name="System Bold" size="18.0" /></font></Label>
            <GridPane hgap="15.0" vgap="15.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="275.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="20.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="130.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="275.0" />
                </columnConstraints>
                <children>
                    <Label text="İşlemci (CPU):" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="pcCpuField" promptText="Ryzen 5, i7 vb." GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <Label text="RAM (GB):" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                    <TextField fx:id="pcRamField" promptText="Örn: 16" GridPane.columnIndex="4" GridPane.rowIndex="0" />
                    <Label text="Ekran Kartı:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <TextField fx:id="pcGpuField" promptText="RTX 3060 vb." GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <Label text="Depolama:" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                    <TextField fx:id="pcStorageField" promptText="512 GB SSD" GridPane.columnIndex="4" GridPane.rowIndex="1" />
                    <Label text="Cihaz Tipi:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField fx:id="pcTypeField" promptText="Laptop/Desktop" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <Label text="Yaş:" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                    <TextField fx:id="pcAgeField" promptText="Örn: 2" GridPane.columnIndex="4" GridPane.rowIndex="2" />
                    <Label text="Ekran:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <TextField fx:id="pcScreenField" promptText="144Hz IPS vb." GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    <Label text="Kozmetik:" GridPane.columnIndex="3" GridPane.rowIndex="3" />
                    <TextField fx:id="pcConditionField" promptText="Temiz" GridPane.columnIndex="4" GridPane.rowIndex="3" />
                </children>
                <rowConstraints><RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints /></rowConstraints>
            </GridPane>
            <Separator prefWidth="200.0" />
            <HBox alignment="CENTER" spacing="15.0">
                <children>
                    <Button fx:id="calculateButton2" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 8;" text="BİLGİSAYAR DEĞERİ HESAPLA"><font><Font name="System Bold" size="14.0" /></font></Button>
                    <Button fx:id="clearButton2" prefHeight="45.0" prefWidth="120.0" style="-fx-background-color: #bdc3c7; -fx-text-fill: #2c3e50; -fx-background-radius: 8;" text="FORMU SIFIRLA" />
                </children>
            </HBox>
            <Label fx:id="pcResultLabel" alignment="CENTER" maxWidth="Infinity" text="Tahmini Değer: -- ₺" textFill="#8e44ad"><font><Font name="System Bold" size="20.0" /></font></Label>
        </children>
    </VBox>
</ScrollPane>