<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.valuwise.controller.PcController">
    <VBox spacing="20.0">
        <padding><Insets bottom="20.0" left="30.0" right="30.0" top="20.0" /></padding>
        <children>
            <Label text="PC Değeri Hesaplama İçin Veri Girişi" textFill="#2c3e50"><font><Font name="System Bold" size="18.0" /></font></Label>
            <GridPane hgap="15.0" vgap="15.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="170.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="250.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="20.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="170.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="250.0" />
                </columnConstraints>
                <children>
                    <Label text="Cihaz Tipi:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <ComboBox fx:id="pcCihazTipiCombo" maxWidth="Infinity" promptText="Seçiniz" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <Label text="Marka:" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                    <ComboBox fx:id="pcMarkaCombo" maxWidth="Infinity" promptText="Seçiniz" GridPane.columnIndex="4" GridPane.rowIndex="0" />

                    <Label text="Model Ailesi:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <ComboBox fx:id="pcModelAilesiCombo" maxWidth="Infinity" promptText="Seçiniz" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <Label text="Cihaz Yaşı (Yıl):" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                    <ComboBox fx:id="pcCihazYasiCombo" maxWidth="Infinity" promptText="Seçiniz" GridPane.columnIndex="4" GridPane.rowIndex="1" />

                    <Label text="İşlemci Markası:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <ComboBox fx:id="pcIslemciMarkasiCombo" maxWidth="Infinity" promptText="Seçiniz" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <Label text="İşlemci Ailesi:" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                    <ComboBox fx:id="pcIslemciAilesiCombo" maxWidth="Infinity" promptText="Seçiniz" GridPane.columnIndex="4" GridPane.rowIndex="2" />

                    <Label text="İşlemci Nesli:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <ComboBox fx:id="pcIslemciNesliCombo" maxWidth="Infinity" promptText="Seçiniz" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    <Label text="Ekran Kartı:" GridPane.columnIndex="3" GridPane.rowIndex="3" />
                    <ComboBox fx:id="pcEkranKartiCombo" maxWidth="Infinity" promptText="Seçiniz" GridPane.columnIndex="4" GridPane.rowIndex="3" />

                    <Label text="RAM Kapasitesi:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <ComboBox fx:id="pcRamKapasitesiCombo" maxWidth="Infinity" promptText="Seçiniz" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    <Label text="RAM Tipi:" GridPane.columnIndex="3" GridPane.rowIndex="4" />
                    <ComboBox fx:id="pcRamTipiCombo" maxWidth="Infinity" promptText="Seçiniz" GridPane.columnIndex="4" GridPane.rowIndex="4" />

                    <Label text="Depolama (GB):" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                    <ComboBox fx:id="pcDepolamaKapasitesiCombo" maxWidth="Infinity" promptText="Seçiniz" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                    <Label text="Depolama Tipi:" GridPane.columnIndex="3" GridPane.rowIndex="5" />
                    <ComboBox fx:id="pcDepolamaTipiCombo" maxWidth="Infinity" promptText="Seçiniz" GridPane.columnIndex="4" GridPane.rowIndex="5" />

                    <Label text="Ekran Boyutu:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                    <ComboBox fx:id="pcEkranBoyutuCombo" maxWidth="Infinity" promptText="Seçiniz" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                    <Label text="Batarya Sağlığı:" GridPane.columnIndex="3" GridPane.rowIndex="6" />
                    <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="4" GridPane.rowIndex="6">
                        <Slider fx:id="pcBataryaSagligiSlider" prefWidth="180.0" />
                        <Label fx:id="pcBataryaSagligiLabel" text="90%" />
                    </HBox>

                    <CheckBox fx:id="pcKozmetikHasarCheck" text="Kozmetik Hasar Var" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                    <CheckBox fx:id="pcGarantiCheck" text="Garantisi Devam Ediyor" GridPane.columnIndex="4" GridPane.rowIndex="7" />
                </children>
            </GridPane>

            <Separator prefWidth="200.0" />

            <HBox alignment="CENTER" spacing="15.0">
                <children>
                    <Button fx:id="calculateButton" onAction="#onCalculateButtonClick" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 8;" text="PC DEĞERİ HESAPLA"><font><Font name="System Bold" size="14.0" /></font></Button>
                    <Button fx:id="clearButton" onAction="#onClearButtonClick" prefHeight="45.0" prefWidth="120.0" style="-fx-background-color: #bdc3c7; -fx-text-fill: #2c3e50; -fx-background-radius: 8;" text="FORMU SIFIRLA" />
                </children>
            </HBox>
            <Label fx:id="errorLabel" text="Eksik veya hatalı giriş yaptınız!" textFill="RED" visible="false" />
            <Label fx:id="pcResultLabel" alignment="CENTER" maxWidth="Infinity" text="Tahmini Değer: -- ₺" textFill="#8e44ad"><font><Font name="System Bold" size="20.0" /></font></Label>
        </children>
    </VBox>
</ScrollPane>