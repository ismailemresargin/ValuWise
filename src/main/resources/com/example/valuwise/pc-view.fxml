<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.valuwise.HelloController">
    <VBox spacing="20.0">
        <padding><Insets bottom="20.0" left="30.0" right="30.0" top="20.0" /></padding>
        <children>
            <Label text="PC Değeri Hesaplama İçin Veri Girişi" textFill="#2c3e50"><font><Font name="System Bold" size="18.0" /></font></Label>

            <GridPane hgap="15.0" vgap="15.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="170.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="250.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="20.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="170.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="250.0" />
                </columnConstraints>
                <children>
                    <!-- Satır 1 -->
                    <Label text="Cihaz Tipi:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="pcCihazTipiField" promptText="Masaüstü / Dizüstü" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <Label text="Marka:" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                    <TextField fx:id="pcMarkaField" promptText="Asus, Apple vb." GridPane.columnIndex="4" GridPane.rowIndex="0" />

                    <!-- Satır 2 -->
                    <Label text="Model Ailesi:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <TextField fx:id="pcModelAilesiField" promptText="ROG, ThinkPad vb." GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <Label text="Cihaz Yaşı (Yıl):" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                    <TextField fx:id="pcCihazYasiField" promptText="Yıl olarak Giriniz" GridPane.columnIndex="4" GridPane.rowIndex="1" />

                    <!-- Satır 3 -->
                    <Label text="İşlemci Markası:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField fx:id="pcIslemciMarkasiField" promptText="Intel, AMD vb." GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <Label text="İşlemci Ailesi:" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                    <TextField fx:id="pcIslemciAilesiField" promptText="i7, Ryzen 5 vb." GridPane.columnIndex="4" GridPane.rowIndex="2" />

                    <!-- Satır 4 -->
                    <Label text="İşlemci Nesli:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <TextField fx:id="pcIslemciNesliField" promptText="Örn: 12" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    <Label text="Ekran Kartı:" GridPane.columnIndex="3" GridPane.rowIndex="3" />
                    <TextField fx:id="pcEkranKartiField" promptText="RTX 4060, Dahili vb." GridPane.columnIndex="4" GridPane.rowIndex="3" />

                    <!-- Satır 5 -->
                    <Label text="RAM Kapasitesi (GB):" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <TextField fx:id="pcRamKapasitesiField" promptText="GB Cinsinden Yazın" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    <Label text="RAM Tipi:" GridPane.columnIndex="3" GridPane.rowIndex="4" />
                    <TextField fx:id="pcRamTipiField" promptText="DDR4, DDR5 vb." GridPane.columnIndex="4" GridPane.rowIndex="4" />

                    <!-- Satır 6 -->
                    <Label text="Depolama (GB):" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                    <TextField fx:id="pcDepolamaKapasitesiField" promptText="GB Cinsinden Yazın" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                    <Label text="Depolama Tipi:" GridPane.columnIndex="3" GridPane.rowIndex="5" />
                    <TextField fx:id="pcDepolamaTipiField" promptText="NVMe, HDD vb." GridPane.columnIndex="4" GridPane.rowIndex="5" />

                    <!-- Satır 7 -->
                    <Label text="Ekran Boyutu (İnç):" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                    <TextField fx:id="pcEkranBoyutuField" promptText="INC Cinsinden Yazın" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                    <Label text="Batarya Sağlığı (%):" GridPane.columnIndex="3" GridPane.rowIndex="6" />
                    <TextField fx:id="pcBataryaSagligiField" promptText="\% olarak Giriniz" GridPane.columnIndex="4" GridPane.rowIndex="6" />

                    <!-- Satır 8 -->
                    <Label text="Kozmetik Hasar:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                    <TextField fx:id="pcKozmetikHasarField" promptText="Var / Yok" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                    <Label text="Garantisi Var mı:" GridPane.columnIndex="3" GridPane.rowIndex="7" />
                    <TextField fx:id="pcGarantiField" promptText="Var / Yok" GridPane.columnIndex="4" GridPane.rowIndex="7" />
                </children>
            </GridPane>

            <Separator prefWidth="200.0" />

            <HBox alignment="CENTER" spacing="15.0">
                <children>
                    <Button fx:id="calculateButton2" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 8;" text="PC DEĞERİ HESAPLA"><font><Font name="System Bold" size="14.0" /></font></Button>
                    <Button fx:id="clearButton2" prefHeight="45.0" prefWidth="120.0" style="-fx-background-color: #bdc3c7; -fx-text-fill: #2c3e50; -fx-background-radius: 8;" text="FORMU SIFIRLA" />
                </children>
            </HBox>

            <Label fx:id="pcResultLabel" alignment="CENTER" maxWidth="Infinity" text="Tahmini Değer: -- ₺" textFill="#8e44ad"><font><Font name="System Bold" size="20.0" /></font></Label>
        </children>
    </VBox>
</ScrollPane>