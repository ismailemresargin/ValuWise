<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.valuwise.HelloController">
    <VBox spacing="20.0">
        <padding><Insets bottom="20.0" left="30.0" right="30.0" top="20.0" /></padding>
        <children>
            <Label text="Konut Değeri Hesaplama İçin Veri Girişi" textFill="#2c3e50"><font><Font name="System Bold" size="18.0" /></font></Label>
            <GridPane hgap="15.0" vgap="15.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="120.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="275.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="20.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="120.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="275.0" />
                </columnConstraints>
                <children>
                    <Label text="Şehir / İlçe / Mahalle:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="houseLocationField" promptText="Örn: Trabzon / Ortahisar" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <Label text="Net Metrekare (m²):" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                    <TextField fx:id="houseAreaField" promptText="Örn: 135" GridPane.columnIndex="4" GridPane.rowIndex="0" />
                    <Label text="Oda Sayısı:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <TextField fx:id="houseRoomsField" promptText="Örn: 3+1" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <Label text="Bina Yaşı:" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                    <TextField fx:id="houseAgeField" promptText="Örn: 5" GridPane.columnIndex="4" GridPane.rowIndex="1" />
                    <Label text="Bulunduğu Kat:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField fx:id="houseFloorField" promptText="Örn: 4" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <Label text="Isınma Tipi:" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                    <TextField fx:id="houseHeatingField" promptText="Doğalgaz, Merkezi vb." GridPane.columnIndex="4" GridPane.rowIndex="2" />
                    <Label text="Krediye Uygunluk:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <TextField fx:id="houseCreditStatusField" promptText="Evet / Hayır" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    <Label text="Balkon / Teras:" GridPane.columnIndex="3" GridPane.rowIndex="3" />
                    <TextField fx:id="houseBalconyField" promptText="Örn: 2 Balkonlu" GridPane.columnIndex="4" GridPane.rowIndex="3" />
                </children>
                <rowConstraints><RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints /></rowConstraints>
            </GridPane>
            <Separator prefWidth="200.0" />
            <HBox alignment="CENTER" spacing="15.0">
                <children>
                    <Button fx:id="calculateButton1" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 8;" text="KONUT DEĞERİ HESAPLA"><font><Font name="System Bold" size="14.0" /></font></Button>
                    <Button fx:id="clearButton1" prefHeight="45.0" prefWidth="120.0" style="-fx-background-color: #bdc3c7; -fx-text-fill: #2c3e50; -fx-background-radius: 8;" text="FORMU SIFIRLA" />
                </children>
            </HBox>
            <Label fx:id="houseResultLabel" alignment="CENTER" maxWidth="Infinity" text="Tahmini Değer: -- ₺" textFill="#2980b9"><font><Font name="System Bold" size="20.0" /></font></Label>
        </children>
    </VBox>
</ScrollPane>